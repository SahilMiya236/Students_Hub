    # ── Number Guessing Game ─────────────────────────────────────

    def show_number_guessing(self):
        self.clear_window()
        outer = self._base_frame()
        card  = self._centered_card(outer)

        make_title_bar(card, "NUMBER GUESSING GAME", "🔢")

        body = tk.Frame(card, bg=CARD, padx=30, pady=18)
        body.pack(fill="both", expand=True)

        make_label(body,
            "I'm thinking of a number between 1 and 100.\nCan you guess it? 🤔",
            font=FONT_SUBTITLE, justify="center").pack(pady=(0, 16))

        number   = [random.randint(1, 100)]
        attempts = [0]

        # Stats row
        stats = tk.Frame(body, bg=CARD)
        stats.pack(fill="x", pady=(0, 12))
        attempts_var  = tk.StringVar(value="Attempts:  0")
        attempts_lbl  = tk.Label(stats, textvariable=attempts_var,
                                 font=("Segoe UI", 11, "bold"),
                                 bg=CARD, fg=ACCENT)
        attempts_lbl.pack(side="left")

        result_var = tk.StringVar(value="")
        result_lbl = tk.Label(body, textvariable=result_var,
                              font=("Segoe UI", 13, "bold"),
                              bg=CARD, fg=WARNING)
        result_lbl.pack(pady=8)

        make_label(body, "Enter your guess:", fg=SUBTEXT,
                   font=FONT_SMALL).pack(anchor="w")
        guess_entry = make_entry(body)
        guess_entry.pack(fill="x", ipady=8, pady=(4, 12))
        guess_entry.focus()

        def check():
            try:
                g = int(guess_entry.get())
                attempts[0] += 1
                attempts_var.set(f"Attempts:  {attempts[0]}")
                if g < number[0]:
                    result_var.set("📉  Too low — try higher!")
                    result_lbl.config(fg=DANGER)
                elif g > number[0]:
                    result_var.set("📈  Too high — try lower!")
                    result_lbl.config(fg=WARNING)
                else:
                    result_var.set(
                        f"🎉  Correct! You got it in {attempts[0]} attempt(s)!")
                    result_lbl.config(fg=SUCCESS)
                    guess_entry.config(state="disabled")
                    check_btn.config(state="disabled")
                    again_btn.config(state="normal")
                guess_entry.delete(0, tk.END)
                guess_entry.focus()
            except ValueError:
                messagebox.showerror("Invalid", "Please enter a whole number.")
                guess_entry.delete(0, tk.END)

        def play_again():
            number[0]   = random.randint(1, 100)
            attempts[0] = 0
            attempts_var.set("Attempts:  0")
            result_var.set("")
            guess_entry.config(state="normal")
            check_btn.config(state="normal")
            again_btn.config(state="disabled")
            guess_entry.delete(0, tk.END)
            guess_entry.focus()

        guess_entry.bind("<Return>", lambda e: check())

        btn_row = tk.Frame(body, bg=CARD)
        btn_row.pack(fill="x", pady=6)
        check_btn = make_btn(btn_row, "Check Guess ✔", check,
                             color=ACCENT, hover=BTN_HVR, width=16, pady=10)
        check_btn.pack(side="left", padx=4)
        again_btn = make_btn(btn_row, "Play Again 🔄", play_again,
                             color=SUCCESS, hover="#047857",
                             width=14, pady=10)
        again_btn.config(state="disabled")
        again_btn.pack(side="left", padx=4)
        make_btn(btn_row, "← Back", self.show_games_menu,
                 color=BTN_BACK, hover=BTN_BACK_HVR,
                 width=10, pady=10).pack(side="left", padx=4)

    # ── Flappy Bird ──────────────────────────────────────────────

    def play_flappy_bird(self):
        import subprocess, os, sys
        path = os.path.join(os.path.dirname(__file__), "flappybird.py")
        try:
            messagebox.showinfo(
                "🐦 Flappy Bird",
                "Starting Flappy Bird…\nClose the game window to return to the menu.")
            subprocess.Popen([sys.executable, path])
        except Exception as ex:
            messagebox.showerror("Error", f"Could not start Flappy Bird:\n{ex}")


